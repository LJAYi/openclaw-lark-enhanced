{
  "name": "openclaw-lark-enhanced",
  "version": "0.1.2",
  "type": "module",
  "description": "Third-party, non-official OpenClaw Lark/Feishu enhancement plugin. Currently includes a thread/topic completion routing fix without modifying the official plugin.",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "feishu",
    "lark",
    "thread",
    "subagent",
    "plugin"
  ],
  "files": [
    "index.js",
    "openclaw.plugin.json",
    "README.md",
    "QUICKSTART.md",
    "bin"
  ],
  "bin": {
    "openclaw-lark-enhanced": "bin/openclaw-lark-enhanced.js"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.7"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": ["./index.js"],
    "compat": {
      "pluginApi": ">=2026.4.7",
      "minGatewayVersion": "2026.4.7"
    },
    "build": {
      "openclawVersion": "2026.4.7",
      "pluginSdkVersion": "2026.4.7"
    }
  }
}
